        "interviewDate": { "type": "string", "format": "date-time" },
        "problemTheme": { "type": "string" },
        "painIntensity": { "type": "number", "minimum": 1, "maximum": 5 },
        "mentionSpontaneous": { "type": "boolean" },
        "currentAlternative": { "type": "string" },
        "bestQuote": { "type": "string" },
        "followUpNeeded": { "type": "boolean" },
        "notes": { "type": "string" },
        "countsTowardMinimum": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "companyId", 
        "interviewerPersonId", 
        "intervieweeName", 
        "intervieweeSegment", 
        "interviewSource", 
        "interviewDate", 
        "problemTheme", 
        "painIntensity", 
        "mentionSpontaneous", 
        "currentAlternative", 
        "bestQuote", 
        "followUpNeeded", 
        "notes", 
        "countsTowardMinimum", 
        "createdAt", 
        "updatedAt"
      ]
    },
