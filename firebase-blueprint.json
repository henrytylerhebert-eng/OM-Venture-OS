{
  "entities": {
    "organization": {
      "title": "Organization",
      "description": "An entity in the ecosystem (OM, startup, mentor org, etc).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["om", "startup", "mentor_org", "investor_org", "university", "partner"] },
        "website": { "type": "string" },
        "region": { "type": "string" },
        "active": { "type": "boolean" },
        "relationshipOwnerId": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "active", "createdAt", "updatedAt"]
    },
    "person": {
      "title": "Person",
      "description": "A person in the system (OM staff, founder, mentor, investor).",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "fullName": { "type": "string" },
        "primaryEmail": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "organizationId": { "type": "string" },
        "roleType": { "type": "string", "enum": ["om_admin", "om_staff", "founder", "startup_team", "mentor", "investor_reviewer", "investor_admin"] },
        "title": { "type": "string" },
        "linkedinUrl": { "type": "string" },
        "active": { "type": "boolean" },
        "authUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "fullName", "primaryEmail", "organizationId", "roleType", "active", "createdAt", "updatedAt"]
    },
    "company": {
      "title": "Company",
      "description": "A startup or company in the ecosystem.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "organizationId": { "type": "string" },
        "founderLeadPersonId": { "type": "string" },
        "description": { "type": "string" },
        "website": { "type": "string" },
        "membershipStatus": { "type": "string", "enum": ["active", "inactive", "alumni", "pending"] },
        "confirmedMembershipLevel": { "type": "string" },
        "active": { "type": "boolean" },
        "omOwnerPersonId": { "type": "string" },
        "currentPortfolioProgressId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "organizationId", "active", "createdAt", "updatedAt"]
    },
    "cohort": {
      "title": "Cohort",
      "description": "A startup support cohort program.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "programType": { "type": "string", "enum": ["builder_1_0", "builder_2_0", "startup_circle", "mentor_program"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["planned", "active", "completed"] },
        "programOwnerPersonId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "programType", "status", "createdAt", "updatedAt"]
    },
    "cohortApplication": {
      "title": "Cohort Application",
      "description": "A founder's request to join a cohort.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "founderPersonId": { "type": "string" },
        "requestedCohortId": { "type": "string" },
        "submissionNotes": { "type": "string" },
        "decision": { "type": "string", "enum": ["pending", "approved", "declined", "waitlist"] },
        "fitNotes": { "type": "string" },
        "decidedByPersonId": { "type": "string" },
        "decidedAt": { "type": "string", "format": "date-time" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "founderPersonId", "requestedCohortId", "decision", "submittedAt", "updatedAt"]
    },
    "cohortParticipation": {
      "title": "Cohort Participation",
      "description": "An active record of a company in a cohort.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "cohortId": { "type": "string" },
        "founderLeadPersonId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "withdrawn"] },
        "joinDate": { "type": "string", "format": "date-time" },
        "miroUrl": { "type": "string" },
        "customerDiscoveryTrackerUrl": { "type": "string" },
        "interviewTarget": { "type": "number" },
        "interviewCount": { "type": "number" },
        "homeworkStatus": { "type": "string", "enum": ["on_track", "behind", "complete"] },
        "graduationReady": { "type": "boolean" },
        "completionCertificateUrl": { "type": "string" },
        "nextProgramEligible": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "cohortId", "status", "interviewTarget", "interviewCount", "graduationReady", "nextProgramEligible", "createdAt", "updatedAt"]
    },
    "portfolioProgress": {
      "title": "Portfolio Progress",
      "description": "Tracking the stage and progress of a startup.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "recommendedStage": { "type": "string", "enum": ["idea_development", "customer_discovery", "product_development", "beta_testing", "customer_acquisition", "growth", "alumni"] },
        "stageOverride": { "type": "string", "enum": ["idea_development", "customer_discovery", "product_development", "beta_testing", "customer_acquisition", "growth", "alumni"] },
        "finalStage": { "type": "string", "enum": ["idea_development", "customer_discovery", "product_development", "beta_testing", "customer_acquisition", "growth", "alumni"] },
        "progressScore": { "type": "number" },
        "stageConfidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "fundingStage": { "type": "string", "enum": ["none", "friends_family", "pre_seed", "seed", "series_a_plus", "non_dilutive", "revenue_funded"] },
        "primaryProofType": { "type": "string", "enum": ["interviews", "pattern", "mvp_live", "beta_users", "pilots", "lois", "revenue", "growth"] },
        "primaryProofDetail": { "type": "string" },
        "liveProduct": { "type": "boolean" },
        "betaLive": { "type": "boolean" },
        "revenueStarted": { "type": "boolean" },
        "payingCustomersCount": { "type": "number" },
        "nextMilestone": { "type": "string" },
        "biggestBlocker": { "type": "string" },
        "omOwnerPersonId": { "type": "string" },
        "stageUpdatedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "recommendedStage", "finalStage", "progressScore", "liveProduct", "betaLive", "revenueStarted", "payingCustomersCount", "stageUpdatedAt", "updatedAt"]
    },
    "mentor": {
      "title": "Mentor",
      "description": "A mentor profile.",
      "type": "object",
      "properties": {
        "personId": { "type": "string" },
        "organizationId": { "type": "string" },
        "expertiseAreas": { "type": "array", "items": { "type": "string" } },
        "stageFit": { "type": "array", "items": { "type": "string" } },
        "geography": { "type": "string" },
        "shareEmail": { "type": "boolean" },
        "active": { "type": "boolean" },
        "lastEngagedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["personId", "expertiseAreas", "stageFit", "shareEmail", "active", "createdAt", "updatedAt"]
    },
    "mentorAssignment": {
      "title": "Mentor Assignment",
      "description": "A mentor assigned to a company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "founderPersonId": { "type": "string" },
        "mentorId": { "type": "string" },
        "assignedByPersonId": { "type": "string" },
        "assignmentType": { "type": "string", "enum": ["requested", "staff_matched", "milestone_based"] },
        "goal": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "paused"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "mentorId", "assignedByPersonId", "assignmentType", "status", "createdAt", "updatedAt"]
    },
    "meetingRequest": {
      "title": "Meeting Request",
      "description": "A request for a meeting between a founder and a mentor.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "founderPersonId": { "type": "string" },
        "mentorId": { "type": "string" },
        "mentorAssignmentId": { "type": "string" },
        "requestedByPersonId": { "type": "string" },
        "reason": { "type": "string" },
        "programContext": { "type": "string" },
        "status": { "type": "string", "enum": ["requested", "scheduled", "completed", "cancelled"] },
        "meetingDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "followUpNeeded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "founderPersonId", "mentorId", "requestedByPersonId", "status", "followUpNeeded", "createdAt", "updatedAt"]
    },
    "feedback": {
      "title": "Feedback",
      "description": "Meeting notes and feedback.",
      "type": "object",
      "properties": {
        "meetingRequestId": { "type": "string" },
        "companyId": { "type": "string" },
        "founderPersonId": { "type": "string" },
        "mentorId": { "type": "string" },
        "submittedByRole": { "type": "string", "enum": ["founder", "mentor", "om_staff"] },
        "overallRating": { "type": "number" },
        "willingToFollowUp": { "type": "boolean" },
        "shareableProof": { "type": "string" },
        "internalNotes": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["meetingRequestId", "companyId", "submittedByRole", "submittedAt"]
    },
    "sourceSubmission": {
      "title": "Source Submission",
      "description": "Raw source capture for Airtable-anchored and Jotform-origin evidence before normalization.",
      "type": "object",
      "properties": {
        "sourceSystem": { "type": "string", "enum": ["jotform", "airtable"] },
        "sourceLane": { "type": "string", "enum": ["discovery_plan", "meeting_notes"] },
        "sourceFormId": { "type": "string" },
        "sourceFormTitle": { "type": "string" },
        "sourceSubmissionId": { "type": "string" },
        "sourceSubmittedAt": { "type": "string", "format": "date-time" },
        "sourceUpdatedAt": { "type": "string", "format": "date-time" },
        "sourceSubmitterName": { "type": "string" },
        "sourceSubmitterEmail": { "type": "string" },
        "sourceCompanyText": { "type": "string" },
        "sourceFounderText": { "type": "string" },
        "sourceMeetingDate": { "type": "string", "format": "date-time" },
        "sourceTopicText": { "type": "string" },
        "sourceQuestionSetType": { "type": "string" },
        "rawPayload": { "type": "object" },
        "sourceHash": { "type": "string" },
        "matchedCompanyId": { "type": "string" },
        "matchedPersonId": { "type": "string" },
        "matchConfidence": { "type": "string", "enum": ["high", "medium", "low", "unresolved"] },
        "ingestionStatus": {
          "type": "string",
          "enum": ["received", "matched", "needs_review", "ready_to_normalize", "normalized", "ignored"]
        },
        "ingestionNotes": { "type": "string" },
        "normalizedTargets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "targetType": {
                "type": "string",
                "enum": ["interview", "discovery_plan", "interview_guide", "evidence_artifact", "linked_note"]
              },
              "targetId": { "type": "string" },
              "normalizedAt": { "type": "string", "format": "date-time" }
            },
            "required": ["targetType", "targetId", "normalizedAt"]
          }
        },
        "matchedByPersonId": { "type": "string" },
        "matchedAt": { "type": "string", "format": "date-time" },
        "normalizedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "sourceSystem",
        "sourceLane",
        "sourceFormId",
        "sourceFormTitle",
        "sourceSubmissionId",
        "rawPayload",
        "sourceHash",
        "matchConfidence",
        "ingestionStatus",
        "normalizedTargets",
        "createdAt",
        "updatedAt"
      ]
    },
    "ingestionReviewItem": {
      "title": "Ingestion Review Item",
      "description": "Staff review record for raw source submissions that are unresolved or awaiting normalization decisions.",
      "type": "object",
      "properties": {
        "sourceSubmissionId": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved"] },
        "reviewReason": {
          "type": "string",
          "enum": [
            "ambiguous_company_match",
            "ambiguous_person_match",
            "match_conflict",
            "canonical_collision",
            "weak_content",
            "legacy_context",
            "malformed_submission"
          ]
        },
        "actionNeeded": { "type": "string" },
        "proposedCompanyId": { "type": "string" },
        "proposedPersonId": { "type": "string" },
        "proposedConfidence": { "type": "string", "enum": ["high", "medium", "low", "unresolved"] },
        "reviewedByPersonId": { "type": "string" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "resolutionType": {
          "type": "string",
          "enum": ["accept_proposed_match", "override_match", "ready_to_normalize", "mark_unresolved", "ignore"]
        },
        "resolutionNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "sourceSubmissionId",
        "status",
        "reviewReason",
        "actionNeeded",
        "proposedConfidence",
        "createdAt",
        "updatedAt"
      ]
    },
    "interview": {
      "title": "Interview",
