# Choose how the copilot should run.
# auto = OpenAI when configured, otherwise heuristic fallback.
AI_PROVIDER="auto"

# Recommended model setup for the Venture Copilot backend.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_MODEL="gpt-5"

# Local backend port used by the Express API.
PORT="8787"

# Optional Vite proxy override.
VITE_API_PROXY_TARGET="http://localhost:8787"

# Optional app URL for future callback/deployment work.
APP_URL="http://localhost:3000"

# Admin-only seed helper for the approved OM starter records.
# Use either FIREBASE_SERVICE_ACCOUNT_JSON or GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project-id"}'
